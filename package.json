{
  "name": "ebook-translator-workbench",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npx concurrently -n be,fe -c blue,green \"npm run dev --workspace backend\" \"npm run dev --workspace frontend\"",
    "dev:frontend": "npm run dev --workspace frontend",
    "dev:backend": "npm run dev --workspace backend",
    "build": "npm run build --workspace frontend",
    "start": "npm run start --workspace backend",
    "test:integration": "node backend/scripts/integration-test.js",
    "test:packaging": "node backend/scripts/packaging-regression-test.js",
    "epubcheck:install": "bash backend/scripts/install-epubcheck.sh"
  }
}
